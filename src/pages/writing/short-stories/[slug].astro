---
// src/pages/writing/short-stories/[slug].astro
import { type CollectionEntry, getCollection } from 'astro:content';
import MainLayout from '../../../layouts/MainLayout.astro'; // Adjust path if layout is elsewhere

export async function getStaticPaths() {
  const stories = await getCollection('short-stories');
  return stories.map((entry: CollectionEntry<'short-stories'>) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'short-stories'>;
}

const { entry } = Astro.props as Props;
const { Content } = await entry.render();
---
<MainLayout pageTitle={entry.data.title}>
  <article class="prose lg:prose-xl mx-auto py-8">
    <h1>{entry.data.title}</h1>
    {/* Consider adding a publishDate to your schema if you want to display it.
      <p class="text-sm text-gray-600">Published on: {entry.data.publishDate.toLocaleDateString()}</p> 
    */}
    {entry.data.description && <p class="lead italic">{entry.data.description}</p>}
    <hr class="my-6"/>
    <Content />
  </article>
</MainLayout>